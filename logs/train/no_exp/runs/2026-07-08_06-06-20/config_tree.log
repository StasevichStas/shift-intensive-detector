тФВ       train_images_path: /root/shift-intensive-detector/data//train/images                                                                    
тФВ       train_labels_path: /root/shift-intensive-detector/data//train/labels                                                                    
тФВ       val_images_path: /root/shift-intensive-detector/data//val/images                                                                        
тФВ       val_labels_path: /root/shift-intensive-detector/data//val/labels                                                                        
тФВ                                                                                                                                               
тФЬтФАтФА model
