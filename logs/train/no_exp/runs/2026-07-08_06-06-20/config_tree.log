CONFIG
тФЬтФАтФА data
тФВ   тФФтФАтФА augmentations:                                                                                                                          
тФВ       - _target_: torchvision.transforms.v2.RandomGrayscale                                                                                   
тФВ         p: 0.5                                                                                                                                
тФВ       - _target_: torchvision.transforms.v2.RandomPhotometricDistort                                                                          
тФВ         p: 0.1                                                                                                                                
тФВ       - _target_: torchvision.transforms.v2.RandomPerspective                                                                                 
тФВ         distortion_scale: 0.2                                                                                                                 
тФВ         p: 0.3                                                                                                                                
тФВ       _target_: src.data.cs_datamodule.CSDataModule                                                                                           
тФВ       _recursive_: false                                                                                                                      
тФВ       batch_size: 2                                                                                                                           
тФВ       num_workers: 4                                                                                                                          
тФВ       pin_memory: false                                                                                                                       
тФВ       persistent_workers: true                                                                                                                
